@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix film: <http://cinema.fr/film#> .
@prefix cin: <http://cinema.fr/vocab#> .
@prefix genre: <http://cinema.fr/genre#> .
@prefix saison: <http://cinema.fr/saison#> .

cin:Film rdf:type rdfs:Class .
cin:FilmSucces rdf:type rdfs:Class .
cin:FilmEchec rdf:type rdfs:Class .
cin:Film rdfs:subClassOf foaf:Document .
cin:FilmSucces rdfs:subClassOf cin:Film .
cin:FilmEchec rdfs:subClassOf cin:Film .
cin:FilmSucces rdfs:label "Film à succès commercial"@fr .
cin:FilmSucces rdfs:comment "Règle : recettesM > 2 x budgetM (ROI > 2)"@fr .
cin:FilmEchec rdfs:label "Film en échec commercial"@fr .

dc:title rdf:type rdf:Property ; rdfs:domain cin:Film ; rdfs:range rdfs:Literal ; rdfs:label "Titre du film"@fr .
dc:date rdf:type rdf:Property ; rdfs:domain cin:Film ; rdfs:range rdfs:Literal ; rdfs:label "Année de sortie"@fr .
dc:subject rdf:type rdf:Property ; rdfs:domain cin:Film ; rdfs:range cin:Genre ; rdfs:label "Genre (URI vers ressource Genre)"@fr .
dcterms:extent rdf:type rdf:Property ; rdfs:domain cin:Film ; rdfs:range rdfs:Literal ; rdfs:label "Durée en minutes"@fr .
foaf:name rdf:type rdf:Property ; rdfs:domain cin:Film ; rdfs:range rdfs:Literal ; rdfs:label "Nom courant"@fr .
foaf:topic rdf:type rdf:Property ; rdfs:domain cin:Film ; rdfs:range cin:Saison ; rdfs:label "Saison de sortie (URI)"@fr .
cin:budgetM rdf:type rdf:Property ; rdfs:domain cin:Film ; rdfs:range rdfs:Literal ; rdfs:label "Budget en M$ USD"@fr .
cin:recettesM rdf:type rdf:Property ; rdfs:domain cin:Film ; rdfs:range rdfs:Literal ; rdfs:label "Recettes mondiales en M$"@fr .
cin:roi rdf:type rdf:Property ; rdfs:domain cin:Film ; rdfs:range rdfs:Literal ; rdfs:label "ROI = recettes / budget"@fr .
cin:notePresse rdf:type rdf:Property ; rdfs:domain cin:Film ; rdfs:range rdfs:Literal ; rdfs:label "Note presse /10"@fr .
cin:notePublic rdf:type rdf:Property ; rdfs:domain cin:Film ; rdfs:range rdfs:Literal ; rdfs:label "Note public /10"@fr .
cin:nominationsOscar rdf:type rdf:Property ; rdfs:domain cin:Film ; rdfs:range rdfs:Literal ; rdfs:label "Nominations aux Oscars"@fr .
cin:semainesAffiche rdf:type rdf:Property ; rdfs:domain cin:Film ; rdfs:range rdfs:Literal ; rdfs:label "Semaines en exploitation"@fr .
cin:label rdf:type rdf:Property ; rdfs:domain cin:Film ; rdfs:range rdfs:Literal ; rdfs:label "Label ML : 1=succès, 0=échec"@fr .

genre:action rdf:type cin:Genre ; rdfs:label "action"@fr .
genre:animation rdf:type cin:Genre ; rdfs:label "animation"@fr .
genre:aventure rdf:type cin:Genre ; rdfs:label "aventure"@fr .
genre:biopic rdf:type cin:Genre ; rdfs:label "biopic"@fr .
genre:comedie rdf:type cin:Genre ; rdfs:label "comedie"@fr .
genre:drame rdf:type cin:Genre ; rdfs:label "drame"@fr .
genre:fantaisie rdf:type cin:Genre ; rdfs:label "fantaisie"@fr .
genre:guerre rdf:type cin:Genre ; rdfs:label "guerre"@fr .
genre:horreur rdf:type cin:Genre ; rdfs:label "horreur"@fr .
genre:musical rdf:type cin:Genre ; rdfs:label "musical"@fr .
genre:sf rdf:type cin:Genre ; rdfs:label "sf"@fr .
genre:sport rdf:type cin:Genre ; rdfs:label "sport"@fr .
genre:thriller rdf:type cin:Genre ; rdfs:label "thriller"@fr .
genre:western rdf:type cin:Genre ; rdfs:label "western"@fr .
saison:hiver rdf:type cin:Saison ; rdfs:label "Déc–Fév"@fr .
saison:printemps rdf:type cin:Saison ; rdfs:label "Mar–Mai"@fr .
saison:ete rdf:type cin:Saison ; rdfs:label "Juin–Août"@fr .
saison:automne rdf:type cin:Saison ; rdfs:label "Sep–Nov"@fr .

